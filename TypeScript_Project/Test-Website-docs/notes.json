{
  "name": "portfolio-management-app-nodejs",
  "version": "1.0.0",
  "description": "The repository shall contain the applications/programs responsible for handling the portfolio management of the users of the digitization services of Droplet",
  "main": "index.js",
  "directories": {
    "example": "example"
  },
  "scripts": {
    "compile": "tsc -b",
    "dev": "npm run dev -w backend/auth_server && npm run dev -w backend/api_server && npm run dev -w controller & npm run dev -w backend/management",
    "auth": "npm run dev -w backend/auth_server",
    "api": "npm run dev -w backend/api_server",
    "management": "npm run dev -w backend/management",
    "controller": "npm run dev -w controller",
    "start:auth": "npm run start -w backend/auth_server",
    "start:api": "npm run start -w backend/api_server",
    "start:management": "npm run start -w backend/management",
    "start:controller": "npm run start -w controller",
    "test:auth": "npm test -w backend/auth_server",
    "test:api": "npm test -w backend/api_server",
    "test:management": "npm test -w backend/management",
    "lint": "eslint .",
    "lint:staged": "lint-staged",
    "format:check": "prettier --check \"**/*.{js,ts,mjs,json,md,yaml,yml}\"",
    "type:check": "tsc --noEmit",
    "check": "npm run lint && npm run format:check && npm run type:check",
    "prepare": "node -e \"if(process.env.CI !== 'true') process.exit(require('child_process').spawnSync('husky', [], {stdio: 'inherit'}).status)\"",
    "generate-docs": "rm -rf code-documentation/docs/api && typedoc",  
    "docs:start": "npm run start -w code-documentation",
    "docs:build": "npm run build -w code-documentation",
    "docs:cleanup": "rm -rf code-documentation/docs/api",
    "docs:test": "cd code-documentation && npm test"
  },
  "workspaces": [
    "backend/auth_server/",
    "backend/api_server/",
    "backend/management",
    "controller/",
    "packages/*",
    "code-documentation/"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DropletInk/portfolio-management-app-nodejs.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/DropletInk/portfolio-management-app-nodejs/issues"
  },
  "homepage": "https://github.com/DropletInk/portfolio-management-app-nodejs#readme",
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@dropletink/simple-otel-logger": "github:DropletInk/simple-otel-logger",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "crypto": "^1.0.1",
    "handlebars": "^4.7.9",
    "nodemailer": "^8.0.1",
    "openapi3-ts": "^4.5.0",
    "path": "^0.12.7",
    "promises": "^0.2.5",
    "redis": "^5.11.0",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.14",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "shellcheck": "^4.1.0",
    "ts-jest": "^29.4.6",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  },
  "lint-staged": {
    "*.{js,ts,mjs}": ["eslint --fix", "prettier --write"],
    "*.{json,md,yaml,yml}": ["prettier --write"],
    "*.sh": ["shfmt -w", "shellcheck"]
  }
}
