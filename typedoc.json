{
  "entryPoints": ["./"],
  "exclude": [
    "**/build/**",
    "**/dist/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/tests/**",
    "**/node_modules/**",
    "./my-website/**",
    "./Code-Documentation/**",
    "./.docusaurus/**",
    "./docker-compose*",
    "**/jest.config.ts"
  ],

  "entryPointStrategy": "expand",
  "tsconfig": "tsconfig.json",
  "out": "Code-Documentation/docs",
  "plugin": ["typedoc-plugin-markdown"],

  "readme": "none",
  "excludePrivate": true,
  "excludeExternals": true,
  "hideGenerator": true,
  "outputFileStrategy": "modules",

  "disableSources": true,
  "sort": ["source-order"],

  "navigation": {
    "includeCategories": false,
    "includeGroups": false,
    "includeFolders": true
  }
}
